{
  "linter-automatico": {
    "enabled": true,
    "PostToolUse": [
      {
        "matcher": "write_to_file|replace_file_content|multi_replace_file_content",
        "hooks": [
          {
            "type": "command",
            "command": "node .agents/hooks/run-linter.js",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "safety-gate": {
    "enabled": false,
    "PreToolUse": [
      {
        "matcher": "run_command",
        "hooks": [
          {
            "type": "command",
            "command": "node .agents/skills/deploy-helper/scripts/safety-check.js"
          }
        ]
      }
    ]
  }
}
